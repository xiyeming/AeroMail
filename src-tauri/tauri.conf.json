{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AeroMail",
  "version": "0.0.2",
  "identifier": "com.aeromail.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AeroMail",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "transparent": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' http: https: data:; style-src 'self' 'unsafe-inline' http: https:; font-src 'self' http: https:; media-src 'self' http: https:; script-src 'none';"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "dmg", "msi", "nsis"]
  }
}
